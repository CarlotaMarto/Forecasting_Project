knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(tidyverse)
library(lubridate)
library(forecast)
library(tsibble)
library(feasts)
library(fable)
library(knitr)
# Define the correct path for the CSV file
file_path <- "/Users/franciscateixeira/Documents/Forecasting_Project/marriages_queensland/combined_file.csv"
# Load the CSV file
data <- read.csv(file_path)
# Create a Date column from Year and Month
data <- data %>%
mutate(Date = as.Date(paste(year, Month, "1", sep="-"))) %>%
arrange(Date)
# Convert to tsibble
data_ts <- data %>%
select(Date, Marriages) %>%
as_tsibble(index = Date)
# Show the first 10 rows of the dataset
kable(head(data_ts, 10), caption = "First 10 rows of Monthly Marriages Data")
data_ts %\>% ggplot(aes(x=Date, y=Marriages)) + geom_line(color="blue") + labs(title="Monthly Marriages Over Time", x="Date", y="Marriages") + theme_minimal()
# Ensure that dplyr (part of tidyverse) is loaded
library(dplyr)
# Correct code with %>% pipe operator
data_ts %>%
ggplot(aes(x = Date, y = Marriages)) +
geom_line(color="blue") +
labs(title="Monthly Marriages Over Time", x="Date", y="Marriages") +
theme_minimal()
# Ensure that dplyr (part of tidyverse) is loaded
library(dplyr)
# Correct code with %>% pipe operator
data_ts %>%
ggplot(aes(x = Date, y = Marriages)) +
geom_line(color="green") +
labs(title="Monthly Marriages Over Time", x="Date", y="Marriages") +
theme_minimal()
# Ensure that dplyr (part of tidyverse) is loaded
library(dplyr)
# Correct code with %>% pipe operator
data_ts %>%
ggplot(aes(x = Date, y = Marriages)) +
geom_line(color="red") +
labs(title="Monthly Marriages Over Time", x="Date", y="Marriages") +
theme_minimal()
