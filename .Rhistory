library(tidyverse)
library(lubridate)
library(forecast)
library(tsibble)
library(feasts)
library(fable)
library(dplyr)
library(knitr)
# Apply log transformation to stabilize variance if needed
data_ts %>%
mutate(log_Marriages = log(Marriages)) %>%
ggplot(aes(x=Date, y=log_Marriages)) +
geom_line(color="blue") +
labs(title="Log-Transformed Monthly Marriages", x="Date", y="Log of Marriages") +
theme_minimal()
library(fpp3)
library(urca)
library(kableExtra)
japan_data <- aus_arrivals %>%
filter(Origin == "Japan")
japan_data_train <- aus_arrivals %>%
filter(Origin == "Japan") %>%
filter(year(Quarter) < 2011)
library(fpp3)
library(urca)
library(kableExtra)
japan_data <- aus_arrivals %>%
filter(Origin == "Japan")
japan_data_train <- aus_arrivals %>%
filter(Origin == "Japan") %>%
filter(year(Quarter) < 2011)
japan_data_train %>%
mutate(`log(Arrivals)` = log(Arrivals)) %>%
select(-Origin) %>%
pivot_longer(cols = -Quarter) %>%
ggplot()+
geom_line(aes(x=Quarter, y=value)) +
facet_wrap(~ name, scales = 'free_y') +
theme_minimal() +
labs(y='')
japan_data_train %>%
autoplot(difference(Arrivals, 4) %>%  difference()) +
labs(y='')
japan_data_train %>%
gg_tsdisplay(difference(Arrivals, 4) %>%
difference(), plot_type = 'partial')
japan_data_train %>%
model(
arima111011 = ARIMA(Arrivals ~ pdq(1,1,1) + PDQ(0,1,1)),
arima211011 = ARIMA(Arrivals ~ pdq(2,1,1) + PDQ(0,1,1)),
arima111111 = ARIMA(Arrivals ~ pdq(1,1,1) + PDQ(1,1,1)),
arima211111 = ARIMA(Arrivals ~ pdq(2,1,1) + PDQ(1,1,1)),
auto = ARIMA(Arrivals)
) %>%
glance() %>%
select(-c(ar_roots, ma_roots)) %>%
kable()
fit <- japan_data_train %>%
model(
arima111011 = ARIMA(Arrivals ~ pdq(1,1,1) + PDQ(0,1,1)),
arima211011 = ARIMA(Arrivals ~ pdq(2,1,1) + PDQ(0,1,1)),
arima111111 = ARIMA(Arrivals ~ pdq(1,1,1) + PDQ(1,1,1)),
arima211111 = ARIMA(Arrivals ~ pdq(2,1,1) + PDQ(1,1,1)),
auto = ARIMA(Arrivals)
)
fit %>%
select(arima111011) %>%
gg_tsresiduals()
res1 = augment(fit) %>%
filter(.model == 'arima111011') %>%
features(.innov, ljung_box, lag = 11, dof=3)
res2 = augment(fit) %>%
filter(.model == 'arima211011') %>%
features(.innov, ljung_box, lag = 11, dof=4)
res3= augment(fit) %>%
filter(.model == 'arima111111') %>%
features(.innov, ljung_box, lag = 11, dof=4)
res4 = augment(fit) %>%
filter(.model == 'arima211111') %>%
features(.innov, ljung_box, lag = 11, dof=5)
bind_rows(res1, res2, res3, res4) %>%
kable()
fit %>%
forecast(h = 7) %>%
accuracy(japan_data) %>%
kable()
fit %>%
forecast(h = 7) %>%
accuracy(japan_data) %>%
kable()
fit %>%
forecast(h = 7) %>%
filter(.model == 'arima111011') %>%
autoplot(japan_data)
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(tidyverse)
library(lubridate)
library(forecast)
library(dplyr)
library(tidyr)
library(ggplot2)
library(tsibble)
library(feasts)
library(fable)
library(dplyr)
library(knitr)
data %>%
mutate(`log(Marriages)` = log(Marriages)) %>%  # Log transformation
select(-Date) %>%  # Removing the 'Date' column (or keep it if needed)
pivot_longer(cols = -Marriages) %>%  # Reshaping the data to long format
ggplot() +
geom_line(aes(x = index, y = value)) +  # 'index' would be your date or time column
facet_wrap(~ name, scales = 'free_y') +  # Faceting for different variables (if any)
theme_minimal() +
labs(y = 'Log(Number of Marriages)', x = 'Time')
rlang::last_trace()
```r
```r
```r
# Assuming your dataset is named 'data' with columns 'Date' and 'Marriages'
library(dplyr)
library(ggplot2)
# Make sure the column names are correctly referenced
data %>%
mutate(log_Marriages = log(Marriages)) %>%  # Log transformation of 'Marriages'
ggplot(aes(x = Date, y = log_Marriages)) +  # Plot Date vs log-transformed Marriages
geom_line() +
theme_minimal() +
labs(y = 'Log(Number of Marriages)', x = 'Date')
data %>%
mutate(`log(Marriages)` = log(Marriages)) %>%  # Log transformation of 'Marriages'
select(-Date) %>%  # Remove 'Date' column if it's not needed
pivot_longer(cols = -log(Marriages)) %>%  # Reshape data to long format
ggplot() +
geom_line(aes(x = Date, y = value)) +  # Plot Date vs the transformed Marriages
facet_wrap(~ name, scales = 'free_y') +  # Facet for different variables (if applicable)
theme_minimal() +
labs(y = 'Log(Number of Marriages)', x = 'Date')
data %>%
mutate(log_Marriages = log(Marriages)) %>%  # Log transform the 'Marriages' column
select(Date, log_Marriages) %>%  # Only keep 'Date' and the transformed 'log_Marriages'
pivot_longer(cols = -Date) %>%  # Reshape data to long format (only if needed)
ggplot(aes(x = Date, y = value)) +  # Plot 'Date' vs the transformed 'log_Marriages'
geom_line() +
theme_minimal() +
labs(y = 'Log(Number of Marriages)', x = 'Date')
data %>%
mutate(log_Marriages = log(Marriages)) %>%  # Log transform the 'Marriages' column
pivot_longer(cols = c(Marriages, log_Marriages), names_to = "Transformation", values_to = "Value") %>%  # Reshape data to long format
ggplot(aes(x = Date, y = Value)) +  # Plot Date vs the transformed or original 'Marriages'
geom_line() +
facet_wrap(~ Transformation, scales = "free_y") +  # Facet by Transformation (original vs log-transformed)
theme_minimal() +
labs(y = 'Number of Marriages / Log(Number of Marriages)', x = 'Date')
data_ts %>%
ggplot(aes(x = Date, y = Marriages)) +
geom_line(color="red") +
labs(title="Monthly Marriages Over Time", x="Date", y="Marriages") +
theme_minimal()
